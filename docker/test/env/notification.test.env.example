# ==============================================================================
# Whispr Notification Service — Test Environment Variables
# Copy this file to notification.test.env and fill in values before running
# the test docker-compose stack. This file is committed, the real one isn't.
#
# Usage :
#   cd docker/test
#   docker compose --env-file env/notification.test.env -f compose.yml up --abort-on-container-exit
# ==============================================================================

# ------------------------------------------------------------------------------
# PostgreSQL — consumed by the `postgres` service in compose.yml
# ------------------------------------------------------------------------------
POSTGRES_USER=replace_me
POSTGRES_PASSWORD=replace_me
POSTGRES_DB=whispr_notification_test
